---
import BetaSignupForm from "../components/BetaSignupForm.svelte";
import DownloadIOS from "../components/DownloadIOS.svelte";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Ease — Your Personal Health Companion</title>
    <meta name="description" content="Ease helps you understand your body through continuous health monitoring. Join the beta." />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>" />
    <style>
      :root {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        color: #1f1f1f;
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e9f0 100%);
        min-height: 100vh;
      }

      body {
        margin: 0;
        min-height: 100vh;
      }

      /* Header */
      header {
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: #6366f1;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .logo-icon {
        font-size: 1.75rem;
      }

      nav {
        display: flex;
        gap: 2rem;
      }

      nav a {
        color: #666;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
      }

      nav a:hover {
        color: #6366f1;
      }

      /* Hero */
      .hero {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
        text-align: center;
      }

      .hero h1 {
        font-size: 3.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #a78bfa 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0 0 1.5rem 0;
        line-height: 1.2;
      }

      .hero .tagline {
        font-size: 1.5rem;
        color: #555;
        max-width: 600px;
        margin: 0 auto 3rem;
        line-height: 1.6;
      }

      /* Features */
      .features {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
      }

      .feature-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        transition: transform 0.3s, box-shadow 0.3s;
      }

      .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -8px rgba(99, 102, 241, 0.15);
      }

      .feature-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
      }

      .feature-card h3 {
        font-size: 1.25rem;
        margin: 0 0 0.75rem 0;
        color: #1f1f1f;
      }

      .feature-card p {
        color: #666;
        margin: 0;
        line-height: 1.6;
      }

      /* CTA Section */
      .cta-section {
        max-width: 600px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
      }

      /* Download Section */
      .download-section {
        max-width: 600px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
      }

      /* Footer */
      footer {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        text-align: center;
        color: #888;
        font-size: 0.875rem;
        border-top: 1px solid #e5e7eb;
      }

      /* Responsive */
      @media (max-width: 768px) {
        header {
          flex-direction: column;
          gap: 1rem;
        }

        .hero h1 {
          font-size: 2.5rem;
        }

        .hero .tagline {
          font-size: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="logo">
        <span class="logo-icon">🌿</span>
        <span>Ease</span>
      </div>
      <nav>
        <a href="#features">Features</a>
        <a href="#signup">Sign Up</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <h1>Understand Your Body,<br />Simplified.</h1>
        <p class="tagline">
          Ease connects with Apple HealthKit to help you discover patterns, 
          predict onset events, and gain insights into your well-being — 
          all processed locally on your device.
        </p>
      </section>

      <section class="features" id="features">
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">📊</div>
            <h3>Continuous Monitoring</h3>
            <p>Track your health metrics around the clock. See trends emerge over days, weeks, and months.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">⚡</div>
            <h3>Early Onset Detection</h3>
            <p>Our ML models learn your patterns and help predict when something might be coming — before it arrives.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🔒</div>
            <h3>Privacy First</h3>
            <p>Your health data never leaves your device. All processing happens locally — you stay in control.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">📱</div>
            <h3>Apple HealthKit</h3>
            <p>Seamlessly integrates with Apple HealthKit. Import your existing health history in seconds.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🎯</div>
            <h3>Personalized Insights</h3>
            <p>Not generic advice — your insights based on your unique biology and lifestyle patterns.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🌙</div>
            <h3>Daily Journaling</h3>
            <p>Simple daily check-ins help correlate how you feel with what's happening in your body.</p>
          </div>
        </div>
      </section>

      <section class="cta-section" id="signup">
        <BetaSignupForm client:load />
      </section>

      <section class="download-section">
        <DownloadIOS client:load />
      </section>
    </main>

    <footer>
      <p>Ease — Your Personal Health Companion</p>
    </footer>
  </body>
</html>
