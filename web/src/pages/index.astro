---
import BetaSignupForm from "../components/BetaSignupForm.svelte";
import DownloadIOS from "../components/DownloadIOS.svelte";
import NavCta from "../components/NavCta.svelte";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ease — Migraine Tracking</title>
    <meta name="description" content="Track migraine attacks, identify triggers, and discover personalized insights that help you live better. Join the private beta." />
    <meta name="theme-color" content="#1B1B2F" />
    <!-- Social sharing (og:image still TODO — needs a real 1200×630 asset in /public) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Ease — Migraine Tracking" />
    <meta property="og:description" content="Track migraine attacks, identify triggers, and get personalized insights — kept completely private. Join the beta." />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Ease — Migraine Tracking" />
    <meta name="twitter:description" content="Track migraine attacks, identify triggers, and get personalized insights — kept completely private. Join the beta." />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
  </head>
  <body>

    <a class="skip-link" href="#main">Skip to content</a>

    <!-- ░░ ATMOSPHERIC DEPTH ░░ -->
    <div class="atmosphere" aria-hidden="true">
      <div class="orb orb-purple"></div>
      <div class="orb orb-green"></div>
      <div class="orb orb-orange"></div>
    </div>

    <!-- ░░ NAV ░░ -->
    <header class="nav">
      <div class="nav-inner">
        <a class="logo" href="/">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22V12M12 12C12 7 17 3 17 3s-1 5-5 9M12 12C12 7 7 3 7 3s1 5 5 9"/>
          </svg>
          ease
        </a>
        <nav aria-label="Main navigation">
          <a href="#features">Features</a>
          <a href="#about">About</a>
          <a href="#roadmap">Roadmap</a>
          <a href="/profile">Profile</a>
          <a href="/dashboard">Dashboard</a>
          <NavCta client:load />
        </nav>
      </div>
    </header>

    <main id="main">

    <!-- ░░ HERO ░░ -->
    <section class="hero">
      <div class="hero-halo" aria-hidden="true"></div>
      <div class="hero-content">
        <p class="eyebrow reveal">MIGRAINE TRACKING · PRIVATE BETA</p>
        <h1 class="hero-title reveal" style="--d:80ms">
          Know your <em>triggers</em>.<br />Take back your days.
        </h1>
        <p class="hero-sub reveal" style="--d:160ms">
          Ease logs your migraine attacks, surfaces trigger patterns, and puts personalized insights in your pocket — all kept completely private.
        </p>
        <div class="hero-form reveal" id="beta" style="--d:240ms">
          <BetaSignupForm client:load />
        </div>
        <div class="hero-app reveal" style="--d:320ms">
          <DownloadIOS client:load />
        </div>
      </div>
    </section>

    <!-- ░░ FEATURES ░░ -->
    <section class="section features" id="features">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">WHAT EASE DOES</p>
          <h2>Everything you need.<br /><span class="text-muted">Nothing you don't.</span></h2>
        </div>
        <div class="features-grid">

          <article class="card reveal" style="--d:0ms">
            <div class="card-icon icon-purple">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3>Continuous monitoring</h3>
            <p>Log attacks as they happen with quick-entry flows designed for when you're in pain.</p>
          </article>

          <article class="card reveal" style="--d:60ms">
            <div class="card-icon icon-orange">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            </div>
            <h3>Early onset detection</h3>
            <p>Spot prodrome symptoms early and take action before a full attack sets in.</p>
          </article>

          <article class="card reveal" style="--d:120ms">
            <div class="card-icon icon-green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Privacy first</h3>
            <p>Your health data stays on your device. We never sell or share what you track.</p>
          </article>

          <article class="card reveal" style="--d:180ms">
            <div class="card-icon icon-purple">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <h3>Apple HealthKit</h3>
            <p>Connects to Apple Health to bring in your sleep, activity, and vitals automatically.</p>
          </article>

          <article class="card reveal" style="--d:240ms">
            <div class="card-icon icon-orange">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
            <h3>Personalized insights</h3>
            <p>Discover your unique trigger patterns with AI-powered analysis of your history.</p>
          </article>

          <article class="card reveal" style="--d:300ms">
            <div class="card-icon icon-green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <h3>Daily journaling</h3>
            <p>Simple check-ins build a full picture of your health, helping correlate how you feel.</p>
          </article>

        </div>
      </div>
    </section>

    <!-- ░░ PHILOSOPHY ░░ -->
    <section class="section" id="about">
      <div class="container">
        <div class="philosophy reveal">
          <div class="philosophy-text">
            <p class="eyebrow">OUR APPROACH</p>
            <h2>Built for people who live with migraines.</h2>
            <p class="body-text">
              Every interface decision — from the dark-first theme to the quick-entry flows — is built around one question: <em>how does this feel when your head is pounding?</em>
            </p>
            <div class="stats">
              <div class="stat">
                <span class="stat-n">40+</span>
                <span class="stat-l">TRACKED TRIGGERS</span>
              </div>
              <span class="stat-div" aria-hidden="true"></span>
              <div class="stat">
                <span class="stat-n">3</span>
                <span class="stat-l">SEVERITY LEVELS</span>
              </div>
              <span class="stat-div" aria-hidden="true"></span>
              <div class="stat">
                <span class="stat-n">100%</span>
                <span class="stat-l">PRIVATE</span>
              </div>
            </div>
          </div>

          <div class="philosophy-vis" aria-label="Week view showing migraine severity dots">
            <div class="week-strip">
              <div class="week-day">
                <span class="wd-label">MON</span>
                <span class="dot" style="--c:#6B8F71;--g:rgba(107,143,113,0.55)"></span>
                <span class="wd-num">28</span>
              </div>
              <div class="week-day">
                <span class="wd-label">TUE</span>
                <span class="dot" style="--c:#6B8F71;--g:rgba(107,143,113,0.55)"></span>
                <span class="wd-num">29</span>
              </div>
              <div class="week-day today">
                <span class="wd-label">WED</span>
                <span class="dot" style="--c:#E8845C;--g:rgba(232,132,92,0.55)"></span>
                <span class="wd-num">30</span>
              </div>
              <div class="week-day">
                <span class="wd-label">THU</span>
                <span class="dot" style="--c:#6B8F71;--g:rgba(107,143,113,0.55)"></span>
                <span class="wd-num">31</span>
              </div>
              <div class="week-day severe">
                <span class="wd-label">FRI</span>
                <span class="dot" style="--c:#A34A4A;--g:rgba(163,74,74,0.6)"></span>
                <span class="wd-num">1</span>
              </div>
              <div class="week-day">
                <span class="wd-label">SAT</span>
                <span class="dot" style="--c:#6B8F71;--g:rgba(107,143,113,0.55)"></span>
                <span class="wd-num">2</span>
              </div>
              <div class="week-day">
                <span class="wd-label">SUN</span>
                <span class="dot" style="--c:#6B8F71;--g:rgba(107,143,113,0.55)"></span>
                <span class="wd-num">3</span>
              </div>
            </div>
            <p class="vis-label">LAST 7 DAYS</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ░░ ROADMAP ░░ -->
    <section class="section" id="roadmap">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">ROADMAP</p>
          <h2>From private beta<br /><span class="text-muted">to FDA-cleared SaMD.</span></h2>
        </div>
        <div class="roadmap-grid">

          <div class="rm-card reveal" style="--d:0ms">
            <div class="rm-header">
              <span class="rm-badge badge-green">Now</span>
              <span class="rm-phase">Phase 1</span>
            </div>
            <h3 class="rm-title">Private Beta</h3>
            <ul class="rm-list">
              <li>Migraine attack logging with fast-entry UI</li>
              <li>40+ triggers, symptom, and medication tracking</li>
              <li>Apple HealthKit HRV &amp; sleep sync</li>
              <li>Daily check-ins &amp; journaling</li>
              <li>7-day calendar &amp; severity history</li>
            </ul>
            <div class="rm-connector" aria-hidden="true"></div>
          </div>

          <div class="rm-card reveal" style="--d:80ms">
            <div class="rm-header">
              <span class="rm-badge badge-orange">In development</span>
              <span class="rm-phase">Phase 2</span>
            </div>
            <h3 class="rm-title">Predictive Intelligence</h3>
            <ul class="rm-list">
              <li>Bayesian hierarchical model — personalized risk, not population averages</li>
              <li>12h &amp; 24h migraine risk scores with credible intervals</li>
              <li>Calibrated uncertainty: "70% risk, CI 58–82%"</li>
              <li>Contributing factors breakdown per prediction</li>
              <li>Staging inference API with full data contracts</li>
            </ul>
            <div class="rm-connector" aria-hidden="true"></div>
          </div>

          <div class="rm-card reveal" style="--d:160ms">
            <div class="rm-header">
              <span class="rm-badge badge-purple">Planned</span>
              <span class="rm-phase">Phase 3</span>
            </div>
            <h3 class="rm-title">Clinical Validation</h3>
            <ul class="rm-list">
              <li>Real-world pilot cohort (n ≥ 20, ≥ 4 weeks each)</li>
              <li>Ground-truth labeling protocol &amp; governed eval set</li>
              <li>Time-split calibration gates (ECE, Brier score)</li>
              <li>ISO 14971 risk management file</li>
              <li>Human factors usability study plan</li>
            </ul>
            <div class="rm-connector" aria-hidden="true"></div>
          </div>

          <div class="rm-card reveal" style="--d:240ms">
            <div class="rm-header">
              <span class="rm-badge badge-dim">Target</span>
              <span class="rm-phase">Phase 4</span>
            </div>
            <h3 class="rm-title">FDA 510(k) — Class II SaMD</h3>
            <ul class="rm-list">
              <li>Quality Management System (ISO 13485 / 21 CFR 820)</li>
              <li>Design History File (DHF) — complete audit trail</li>
              <li>Post-Market Surveillance &amp; complaint handling plan</li>
              <li>510(k) substantial equivalence submission</li>
              <li>FDA clearance as Class II Software as a Medical Device</li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    </main>

    <!-- ░░ FOOTER ░░ -->
    <footer class="footer">
      <div class="container">
        <div class="footer-row">
          <a class="logo" href="/">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22V12M12 12C12 7 17 3 17 3s-1 5-5 9M12 12C12 7 7 3 7 3s1 5 5 9"/>
            </svg>
            ease
          </a>
          <div class="footer-links">
            <a href="/privacy">Privacy Policy</a>
            <a href="/terms">Terms of Use</a>
          </div>
          <p class="footer-copy">© 2026 Ease Health. Made with care.</p>
        </div>
      </div>
    </footer>

    <script>
      // ── Scroll reveal ──────────────────────────────────────
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // ── Card 3D tilt (skipped for motion-sensitive users) ──
      const allowMotion = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
      if (allowMotion) {
        document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
          card.addEventListener('mousemove', (ev) => {
            const r = card.getBoundingClientRect();
            const x = ev.clientX - r.left, y = ev.clientY - r.top;
            const cx = r.width / 2, cy = r.height / 2;
            card.style.transform =
              `perspective(520px) rotateX(${((y - cy) / cy) * -5}deg) rotateY(${((x - cx) / cx) * 5}deg) translateY(-4px)`;
          });
          card.addEventListener('mouseleave', () => { card.style.transform = ''; });
        });
      }
    </script>

  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #1B1B2F;
    --surface:   rgba(255,255,255,0.035);
    --surface-2: rgba(255,255,255,0.055);
    --surface-h: rgba(108,99,172,0.08);
    --border:    rgba(255,255,255,0.07);
    --border-h:  rgba(108,99,172,0.38);
    --text:      #EDEAF2;
    --text-2:    #E0DDE6;
    --muted:     #7A7690;
    --dim:       #5A5770;
    --purple:    #6C63AC;
    --purple-l:  #A8A0D6;
    --purple-p:  #C0B8E8;
    --green:     #6B8F71;
    --green-t:   #9BC4A2;
    --orange:    #E8845C;
    --orange-l:  #f0a882;
    --radius:    18px;
    --font:      'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Grain texture overlay */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='200' height='200' filter='url(%23n)' opacity='1'/></svg>");
    background-size: 200px 200px;
    opacity: 0.028;
    pointer-events: none;
    z-index: 9999;
  }

  /* ── Atmospheric orbs ─────────────────────────────────────── */
  .atmosphere {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    animation: drift 28s ease-in-out infinite;
  }
  .orb-purple {
    width: 660px; height: 660px;
    background: radial-gradient(circle, rgba(108,99,172,0.28) 0%, transparent 70%);
    top: -130px; left: -130px;
    animation-duration: 26s;
  }
  .orb-green {
    width: 460px; height: 460px;
    background: radial-gradient(circle, rgba(107,143,113,0.20) 0%, transparent 70%);
    bottom: 8%; right: -110px;
    animation-duration: 34s;
    animation-delay: -10s;
    animation-direction: alternate-reverse;
  }
  .orb-orange {
    width: 390px; height: 390px;
    background: radial-gradient(circle, rgba(232,132,92,0.16) 0%, transparent 70%);
    bottom: -70px; left: 22%;
    animation-duration: 24s;
    animation-delay: -6s;
  }
  @keyframes drift {
    0%,100% { transform: translate(0, 0); }
    30%      { transform: translate(22px, -38px); }
    60%      { transform: translate(-16px, 22px); }
  }

  /* ── Layout ───────────────────────────────────────────────── */
  .container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }
  .section { padding: 96px 0; }

  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.13em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .text-muted { color: var(--muted); }

  /* ── Accessibility ────────────────────────────────────────── */
  .skip-link {
    position: absolute;
    left: 16px;
    top: -56px;
    z-index: 200;
    padding: 9px 16px;
    background: var(--surface-2);
    border: 1px solid var(--border-h);
    border-radius: 10px;
    color: var(--text);
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus { top: 16px; }

  :where(a, button, input, [tabindex]):focus-visible {
    outline: 2px solid var(--purple-p);
    outline-offset: 3px;
    border-radius: 6px;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.65s ease, transform 0.65s ease;
    transition-delay: var(--d, 0ms);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── Navigation ───────────────────────────────────────────── */
  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    padding: 0 24px;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: rgba(27,27,47,0.72);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .logo svg { color: var(--purple-l); }

  .nav nav {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav nav a {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav nav a:hover { color: var(--text); }
  .nav nav a:active { transform: translateY(1px); }
  .nav-cta {
    padding: 7px 15px !important;
    background: var(--surface-2) !important;
    border: 1px solid rgba(108,99,172,0.35) !important;
    border-radius: 10px !important;
    color: var(--purple-p) !important;
    font-weight: 600 !important;
    font-size: 12px !important;
    letter-spacing: 0.01em !important;
    transition: background 0.2s, color 0.2s !important;
  }
  .nav-cta:hover {
    background: rgba(108,99,172,0.18) !important;
    color: var(--purple-p) !important;
  }
  .nav-cta-member {
    background: rgba(107,143,113,0.12) !important;
    border-color: rgba(107,143,113,0.32) !important;
    color: var(--green-t) !important;
  }
  .nav-cta-member:hover {
    background: rgba(107,143,113,0.2) !important;
    color: var(--green-t) !important;
  }

  /* ── Hero ─────────────────────────────────────────────────── */
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    padding: 120px 24px 80px;
    text-align: center;
  }
  .hero-halo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -58%);
    width: 740px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(108,99,172,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }
  .hero-content {
    max-width: 660px;
    position: relative;
    z-index: 2;
  }
  .hero-title {
    font-size: clamp(40px, 6.5vw, 74px);
    font-weight: 800;
    line-height: 1.07;
    letter-spacing: -0.035em;
    color: var(--text);
    margin-bottom: 20px;
    text-wrap: balance;
  }
  /* Solid accent + considered underline instead of the generic gradient-text fill */
  .hero-title em {
    font-style: normal;
    color: var(--purple-p);
    position: relative;
    white-space: nowrap;
  }
  .hero-title em::after {
    content: '';
