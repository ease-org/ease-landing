---
import BetaWelcome from "../components/BetaWelcome.svelte";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Beta Access — Ease</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌿</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Atmospheric background -->
    <div class="atmosphere" aria-hidden="true">
      <div class="orb orb-green"></div>
      <div class="orb orb-purple"></div>
    </div>

    <!-- Nav -->
    <header class="nav">
      <div class="nav-inner">
        <a class="logo" href="/">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22V12M12 12C12 7 17 3 17 3s-1 5-5 9M12 12C12 7 7 3 7 3s1 5 5 9"/>
          </svg>
          ease
        </a>
        <span class="nav-badge">Private Beta</span>
      </div>
    </header>

    <!-- Content -->
    <main>
      <BetaWelcome client:load />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-copy">© 2026 Ease Health. Made with care.</p>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #1B1B2F;
    --surface:   rgba(255,255,255,0.035);
    --surface-2: rgba(255,255,255,0.055);
    --surface-h: rgba(108,99,172,0.08);
    --border:    rgba(255,255,255,0.07);
    --border-h:  rgba(108,99,172,0.38);
    --text:      #EDEAF2;
    --text-2:    #E0DDE6;
    --muted:     #7A7690;
    --dim:       #5A5770;
    --purple:    #6C63AC;
    --purple-l:  #A8A0D6;
    --purple-p:  #C0B8E8;
    --green:     #6B8F71;
    --green-t:   #9BC4A2;
    --orange:    #E8845C;
    --orange-l:  #f0a882;
    --font:      'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='200' height='200' filter='url(%23n)' opacity='1'/></svg>");
    background-size: 200px 200px;
    opacity: 0.028;
    pointer-events: none;
    z-index: 9999;
  }

  .atmosphere {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    animation: drift 28s ease-in-out infinite;
  }
  .orb-green {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(107,143,113,0.22) 0%, transparent 70%);
    top: -80px; right: -80px;
    animation-duration: 30s;
  }
  .orb-purple {
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(108,99,172,0.2) 0%, transparent 70%);
    bottom: -60px; left: -60px;
    animation-duration: 24s;
    animation-delay: -8s;
    animation-direction: alternate-reverse;
  }
  @keyframes drift {
    0%,100% { transform: translate(0, 0); }
    40%      { transform: translate(-20px, 28px); }
    70%      { transform: translate(18px, -20px); }
  }

  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    padding: 0 24px;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: rgba(27,27,47,0.72);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .logo svg { color: var(--purple-l); }

  .nav-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-t);
    padding: 4px 10px;
    background: rgba(107,143,113,0.12);
    border: 1px solid rgba(107,143,113,0.25);
    border-radius: 20px;
  }

  main { position: relative; z-index: 2; }

  .footer {
    padding: 32px 24px;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 2;
  }
  .footer-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-copy {
    font-size: 12px;
    color: var(--dim);
  }
</style>
